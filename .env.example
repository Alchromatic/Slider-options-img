# Copy to .env and fill in. .env is git-ignored and must never be committed.

# ── Stripe (TEST MODE) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Supabase ──
SUPABASE_CONNECTION_STRING=

# ── Auth ──
JWT_SECRET=

# ── OAuth — Google ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Facebook ──
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── OAuth redirect / frontend ──
OAUTH_REDIRECT_BASE=
FRONTEND_URL=

# ── TryColors API (measured palette profile generation — server-side ONLY) ──
# Base URL https://api.trycolors.com/v1, auth header X-API-KEY.
# Honors mixerMode="pro" + engine="2025". Free tier: 50 mixes/day, 2 req/sec.
TRYCOLORS_API_KEY=
# Bearer token required by the admin profile-generation endpoint.
ADMIN_TOKEN=
